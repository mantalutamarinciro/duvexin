rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isEmployee() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/employees/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isEmployee();
    }

    function isOwnerUidField() {
      return isSignedIn()
        && resource.data.ownerUid != null
        && resource.data.ownerUid == request.auth.uid;
    }

    function isOwnerUidOnCreate() {
      return isSignedIn()
        && request.resource.data.ownerUid != null
        && request.resource.data.ownerUid == request.auth.uid;
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    match /employees/{employeeId} {
      allow get: if isSignedIn() && (request.auth.uid == employeeId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /*
     * USERS / CUSTOMERS
     * Actuellement, tes documents clients semblent être créés avec des IDs auto
     * via customerService. Donc pas d’ownership fiable sans ownerUid.
     */
    match /users/{userId} {
      allow get: if isStaff() || isOwnerUidField();
      allow list: if isStaff();
      allow create: if isStaff() || isOwnerUidOnCreate();
      allow update: if isStaff() || isOwnerUidField();
      allow delete: if isAdmin();
    }

    /*
     * QUOTES
     * Ton saveQuote passe par Admin SDK côté serveur, donc pas besoin
     * d’ouvrir create au client pour le moment.
     */
    match /quotes/{quoteId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /*
     * BOOKINGS
     * Pour l’instant, tes bookings n’ont pas de customerId / ownerUid fiable.
     * Donc staff only.
     */
    match /bookings/{bookingId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();

      match /inventoryItems/{inventoryItemId} {
        allow get, list: if isStaff();
        allow create, update: if isStaff();
        allow delete: if isAdmin();
      }
    }

    match /vehicles/{vehicleId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    /*
     * Collections legacy / futures
     */
    match /serviceTypes/{serviceTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /movingTrucks/{truckId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /movingTeams/{teamId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin();
    }
  }
}